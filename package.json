{
  "name": "mxl-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write src/",
    "lint": "eslint src/",
    "test": "vitest tests/",
    "test:parity:deep": "PARITY_DEPTH=deep vitest tests/mathml/codegen-parity.test.ts",
    "build:wasm": "emcc src-c/radau5.c src-c/dc_decsol.c src-c/decsol.c src-c/dop853.c src-c/dopri5.c src-c/radau5_wrapper.c src-c/libf2c_stubs.c -I src-c/ -o static/wasm/radau5.js -s WASM=1 -s MODULARIZE=1 -s EXPORT_NAME=RadauModule -s ALLOW_TABLE_GROWTH=1 -s RESERVED_FUNCTION_POINTERS=8 -s EXPORTED_FUNCTIONS='[\"_run_radau5\",\"_run_dop853\",\"_run_dopri5\",\"_set_model_fn\",\"_init_output\",\"_free_output\",\"_get_out_n\",\"_get_out_t\",\"_get_out_y\",\"_malloc\",\"_free\"]' -s EXPORTED_RUNTIME_METHODS='[\"addFunction\",\"removeFunction\",\"ccall\",\"cwrap\",\"HEAPF64\",\"wasmMemory\"]' -O2 -Wno-deprecated-non-prototype"
  },
  "devDependencies": {
    "@eslint/compat": ">=2.1.0",
    "@eslint/js": ">=10.0.0",
    "@sveltejs/adapter-auto": ">=7.0.1",
    "@sveltejs/kit": ">=2.59.0",
    "@sveltejs/vite-plugin-svelte": ">=7.0.0",
    "@types/node": "^25.8.0",
    "eslint": ">=10.0.0",
    "eslint-config-prettier": ">=10.1.8",
    "eslint-plugin-svelte": ">=3.17.1",
    "globals": ">=17.6.0",
    "mdsvex": ">=0.12.7",
    "prettier": ">=3.8.3",
    "prettier-plugin-css-order": ">=2.2.0",
    "prettier-plugin-svelte": ">=3.5.2",
    "svelte": ">=5.55.5",
    "svelte-check": ">=4.4.7",
    "typescript": ">=6.0.3",
    "typescript-eslint": ">=8.59.3",
    "vite": ">=8.0.12",
    "vite-plugin-wasm": ">=3.3.0"
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": ">=7.2.0",
    "@fortawesome/free-solid-svg-icons": ">=7.2.0",
    "@picocss/pico": ">=2.1.1",
    "@sveltejs/adapter-static": ">=3.0.10",
    "chart.js": ">=4.5.0",
    "katex": ">=0.16.44",
    "pyodide": ">=0.29.1",
    "shiki": ">=4.0.2",
    "svelte-fa": ">=4.0.4",
    "svelte-media-queries": ">=1.6.2",
    "vitest": "^4.1.6",
    "wat-compiler": "^1.1.1"
  },
  "overrides": {
    "cookie": ">=1.1.1",
    "eslint": ">=10.0.0",
    "ajv": ">=8.18",
    "minimatch": ">=10.2"
  }
}
