{
  "name": "mxl-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write src/",
    "lint": "eslint src/",
    "test": "vitest tests/",
    "test:parity:deep": "PARITY_DEPTH=deep vitest tests/mathml/codegen-parity.test.ts"
  },
  "devDependencies": {
    "@eslint/compat": ">=2.1.0",
    "@eslint/js": ">=10.0.0",
    "@sveltejs/adapter-auto": ">=7.0.1",
    "@sveltejs/kit": ">=2.61.1",
    "@sveltejs/vite-plugin-svelte": ">=7.0.0",
    "@types/node": "^25.9.0",
    "eslint": ">=10.0.0",
    "eslint-config-prettier": ">=10.1.8",
    "eslint-plugin-svelte": ">=3.18.0",
    "globals": ">=17.6.0",
    "mdsvex": ">=0.12.7",
    "prettier": ">=3.8.3",
    "prettier-plugin-css-order": ">=2.2.0",
    "prettier-plugin-svelte": ">=3.5.2",
    "svelte": ">=5.55.0",
    "svelte-check": ">=4.4.7",
    "typescript": ">=6.0.3",
    "typescript-eslint": ">=8.60.0",
    "vite": ">=8.0.12",
    "vite-plugin-static-copy": "^4.1.0",
    "vite-plugin-wasm": ">=3.3.0"
  },
  "dependencies": {
    "@computational-biology-aachen/design": "github:Computational-Biology-Aachen/design",
    "@computational-biology-aachen/mxlweb-core": "github:Computational-Biology-Aachen/mxlweb-core",
    "@fortawesome/free-brands-svg-icons": ">=7.2.0",
    "@fortawesome/free-solid-svg-icons": ">=7.2.0",
    "@sveltejs/adapter-static": ">=3.0.10",
    "chart.js": ">=4.5.0",
    "katex": "^0.17.0",
    "pyodide": ">=0.29.1",
    "shiki": ">=4.1.0",
    "svelte-fa": ">=4.0.4",
    "svelte-media-queries": ">=1.6.2",
    "vitest": "^4.1.6",
    "wat-compiler": "^1.1.1"
  },
  "overrides": {
    "cookie": ">=1.1.1",
    "eslint": ">=10.0.0",
    "ajv": ">=8.18",
    "minimatch": ">=10.2"
  }
}
